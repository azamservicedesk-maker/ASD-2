{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false
  },
  "include": ["server.ts", "src/routes.ts"],
  "exclude": ["src/app.tsx", "src/main.tsx", "src/hooks/**/*", "src/lib/**/*", "src/pages/**/*", "src/components/**/*", "node_modules"]
}
